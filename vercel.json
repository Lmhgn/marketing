{
  "buildCommand": "cd seo-aeo-dashboard/dashboard && npm install && npm run build",
  "outputDirectory": "seo-aeo-dashboard/dashboard/out",
  "framework": null,
  "rewrites": [
    { "source": "/venue/:slug/", "destination": "/venue/:slug/index.html" },
    { "source": "/competitor/:slug/", "destination": "/competitor/:slug/index.html" },
    { "source": "/action-plan/", "destination": "/action-plan/index.html" },
    { "source": "/benchmarking/", "destination": "/benchmarking/index.html" }
  ]
}
